{
  "name": "zeus-sdk",
  "version": "0.1.0",
  "description": "Scriptorium Animus Iocandi transmedia bundle of tools and resources",
  "type": "module",
  "workspaces": [
    "packages/lib/*",
    "packages/app/*",
    "packages/mcp/*",
    "packages/platform/*",
    "packages/arg/*"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start:solar": "npm run start -w @zeus/solar-system",
    "start:lineas": "npm run start -w @zeus/linea-system",
    "start:editor": "npm run start -w @zeus/editor-ui",
    "start:player": "npm run start -w @zeus/player-ui",
    "start:console-monitor": "npm run start -w @zeus/console-monitor",
    "start:cache-browser": "npm run start -w @zeus/cache-browser",
    "start:firehose": "npm run start -w @zeus/firehose-browser",
    "start:firehose-mcp": "npm run start -w @zeus/linea-firehose",
    "start:socket-server": "npm run start -w @zeus/socket-server",
    "start:player-3d": "npm run start -w @zeus/player-3d-ui",
    "start:3d-monitor": "npm run start -w @zeus/3d-monitor",
    "start:operator-ui": "node packages/operator-ui/serve.mjs",
    "start:v1-zeus": "echo 'Equivalent to VS Code task V1 Zeus ▸ start all — run in parallel terminals:' && echo '  npm run start:socket-server' && echo '  npm run start:console-monitor' && echo '  npm run start:cache-browser' && echo '  npm run start:firehose' && echo 'Or use VS Code: Terminal > Run Task > V1 Zeus ▸ start all'",
    "start:all": "echo 'Equivalent to VS Code task Start ▸ all — run MCP/UI servers in parallel terminals:' && echo '  npm run start:lineas' && echo '  npm run start:editor' && echo '  npm run start:player' && echo '  npm run start:cache-browser' && echo '  npm run start:firehose-mcp' && echo '  npm run start:firehose' && echo '  npm run start:console-monitor' && echo '  npm run start:socket-server' && echo '  npm run start:player-3d' && echo '  npm run start:3d-monitor' && echo '  npm run start:operator-ui' && echo 'Or use VS Code: Terminal > Run Task > Start ▸ all'",

    "demo:game": "npm run demo -w @zeus/game-demos",
    "demo:bots": "npm run demo -w @zeus/ping-pong-bots",
    "demo:arg": "npm run demo -w @zeus/arg-demos",
    "start:arg-console": "npm run start -w @zeus/arg-console",
    "start:arg-player-mcp": "npm run start -w @zeus/arg-player-mcp",
    "start:arg-player-mcp:dos": "node packages/arg/arg-player-mcp/src/start.mjs --actor=dos",
    "test:arg-domain": "npm test -w @zeus/arg-domain",
    "test:arg-console": "npm test -w @zeus/arg-console",
    "test:arg-feeds": "npm test -w @zeus/arg-feeds",
    "test:arg-player-mcp": "npm test -w @zeus/arg-player-mcp",
    "test:arg": "npm run test:arg-domain && npm run test:arg-feeds && npm run test:arg-console && npm run test:arg-player-mcp",

    "test:sdk": "npm test -w @zeus/presets-sdk",
    "test:solar": "npm test -w @zeus/solar-system",
    "test:lineas": "npm test -w @zeus/linea-system",
    "test:firehose-mcp": "npm test -w @zeus/linea-firehose",
    "test:console-monitor": "npm test -w @zeus/console-monitor",
    "test:session-domain": "npm test -w @zeus/session-domain",
    "test:session-protocol": "npm test -w @zeus/session-protocol",
    "test:tablero-core": "npm test -w @zeus/tablero-core",
    "test:http-contract": "npm test -w @zeus/http-contract",
    "test:rooms": "npm test -w @zeus/rooms",
    "test:openapi-mcp-projector": "npm test -w @zeus/openapi-mcp-projector",
    "test:socket-server": "npm test -w @zeus/socket-server",
    "test:ui-3d-kit": "node --test packages/lib/ui-3d-kit/test/*.test.mjs",
    "test:game-engine": "npm test -w @zeus/game-engine",
    "test:operator-bridge": "npm test -w @zeus/operator-bridge",
    "build:operator-ui": "npm --prefix packages/operator-ui install && npm --prefix packages/operator-ui run build:all",

    
    "test:player-3d": "npm test -w @zeus/player-3d-ui",
    "test:3d-monitor": "npm test -w @zeus/3d-monitor",
    "test:bots": "npm test -w @zeus/ping-pong-bots",



    "spec:generate": "npm run spec:generate -w @zeus/protocol",
    "spec:generate:http": "node scripts/spec-generate.mjs",
    "spec:generate:all": "npm run spec:generate:http && npm run spec:generate",
    "test:protocol": "npm test -w @zeus/protocol",
    "test:authority-kit": "npm test -w @zeus/authority-kit",
    "test:playbook-kit": "npm test -w @zeus/playbook-kit",
    "test:view-kit": "npm test -w @zeus/view-kit",
    "test:player-mcp-kit": "npm test -w @zeus/player-mcp-kit",
    "spec:redoc": "node scripts/spec-redoc.mjs",
    "spec:asyncapi:html": "node scripts/spec-asyncapi-html.mjs",
    "spec:studio": "node scripts/spec-studio.mjs",
    "spec:inspector": "node scripts/mcp-inspector.mjs",
    "docs:dev": "node scripts/docs-dev.mjs",
    "docs:build": "npm run spec:generate:all && npm run spec:redoc && npm run spec:asyncapi:html && vitepress build docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "gates": "node scripts/gates/run.mjs",
    "test:gates": "node --test test/gates/*.test.mjs",
    "format": "prettier --write .",
    "seed:aleph": "node scripts/seed-aleph-presets.mjs",
    "stop:services": "node scripts/stop-services.mjs",
    "stop:v1-zeus": "npm run stop:services -- \"V1 Zeus stopped\" socket-server console-monitor cache-browser firehose-browser",
    "stop:arg": "npm run stop:services -- \"ARG stopped\" arg-console arg-player-mcp cache-browser firehose-browser",
    "stop:ports": "bash scripts/stop-ports.sh",
    "e2e": "node e2e/demo.mjs",
    "e2e:deck": "node e2e/deck-demo.mjs",
    "e2e:deck:room": "node e2e/deck-room-demo.mjs",
    "e2e:player-3d": "node e2e/player-3d-demo.mjs",
    "e2e:operator-ui": "node e2e/operator-ui-demo.mjs",
    "e2e:dual-ui": "node e2e/dual-ui-demo.mjs",
    "verify:operator-ui": "npm run test:operator-bridge && npm run build:operator-ui && npm run e2e:operator-ui",
    "verify:dual-ui": "npm run build:operator-ui && npm run e2e:dual-ui",
    "e2e:tablero": "node e2e/tablero-aleph-demo.mjs",
    "e2e:view": "node e2e/view-demo.mjs",
    "e2e:firehose": "node e2e/firehose-demo.mjs",
    "e2e:firehose-links": "node e2e/firehose-links-demo.mjs",
    "e2e:firehose-deck": "node e2e/firehose-deck-demo.mjs",
    "e2e:bridge": "node e2e/e2e-bridge.mjs",
    "e2e:domain": "node e2e/domain.mjs",
    "e2e:domain:manifest": "node e2e/domain-manifest.mjs",
    "e2e:domain:map": "node e2e/domain-map.mjs",
    "e2e:domain:firehose": "node e2e/domain-firehose.mjs",
    "e2e:domain:selection": "node e2e/domain-selection.mjs",
    "e2e:arg": "node e2e/arg-demo.mjs",
    "e2e:arg-feeds": "node e2e/arg-feeds-demo.mjs",
    "e2e:arg-track": "node e2e/arg-track-demo.mjs",
    "e2e:arg-horse": "node e2e/arg-horse-demo.mjs",
    "e2e:arg-mcp": "node e2e/arg-mcp-demo.mjs",
    "e2e:playbook-kit": "node e2e/playbook-kit-demo.mjs"
  },
  "devDependencies": {
    "@alephscript/mcp-core-sdk": "^1.5.0",
    "@asyncapi/cli": "^4.1.1",
    "@asyncapi/html-template": "^3.3.0",
    "@eslint/js": "^9.39.1",
    "@modelcontextprotocol/inspector": "^0.17.0",
    "@redocly/cli": "^1.34.3",
    "@zeus/session-protocol": "*",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "socket.io-client": "^4.8.1",
    "vitepress": "^1.6.3"
  },
  "overrides": {
    "@asyncapi/cli": {
      "next": "14.2.26"
    }
  },
  "license": "AIPLv1"
}

# Zeus presets-sdk environment (copy to .env and adjust)
#
# All runtime configuration uses ZEUS_* variables only.
# Canonical defaults: packages/lib/presets-sdk/src/env/index.mjs

ZEUS_HOST=localhost

# Web UIs
ZEUS_PORT_EDITOR=3012
ZEUS_PORT_PLAYER=3013
ZEUS_PORT_VIEW=3015
ZEUS_PORT_FIREHOSE=3016
ZEUS_PORT_PLAYER_DEBUG=3014
# 3D viewers (three.js visor + debug room-traffic) — E6 visor 3D
ZEUS_PORT_PLAYER_3D=3018
ZEUS_PORT_DEBUG_3D=3019
ZEUS_PORT_OPERATOR_UI=3020

# Scriptorium runtime server (Socket.IO rooms + Admin UI) — E2
ZEUS_PORT_SCRIPTORIUM=3017
# Bridge mode: local (authority) | remote (transparent proxy to upstream)
ZEUS_SCRIPTORIUM_BRIDGE=local
# ZEUS_SCRIPTORIUM_BRIDGE_URL=https://rooms.scriptorium.escrivivir.co
# ZEUS_SCRIPTORIUM_SECRET=dev-secret
# Session transport for player-ui — room master on scriptorium /runtime (legacy /session removed)
ZEUS_SESSION_TRANSPORT=room
# Room used by the room transport. Default: scriptorium.<sessionId> (sessionId = "default").
# Set to pin every session to one fixed room (see resolveSessionRoom in @zeus/rooms).
# ZEUS_SCRIPTORIUM_ROOM=scriptorium.default

# MCP servers
ZEUS_MCP_SUN=4101
ZEUS_MCP_MOON=4102
ZEUS_MCP_EARTH=4103
ZEUS_MCP_LINEA_ESPAN=4111
ZEUS_MCP_LINEA_WP=4112
ZEUS_MCP_FORCES=4113
ZEUS_MCP_SSB=4114
ZEUS_MCP_FIREHOSE=3008

# Spec tooling (AsyncAPI Studio, VitePress docs, MCP Inspector)
ZEUS_PORT_SPEC_STUDIO=3210
ZEUS_PORT_DOCS=3230
ZEUS_PORT_INSPECTOR=6274
ZEUS_PORT_INSPECTOR_PROXY=6277
ZEUS_INSPECTOR_TOKEN=zeus-dev-inspector

# MCP mutation prompts (human-in-the-loop gate)
ZEUS_MCP_APPROVAL_TOKEN=APROBAR

# Optional: extra MCP base URLs for catalog discovery (comma-separated)
# ZEUS_DISCOVERY_URLS=http://localhost:5001,http://localhost:5002

# Volumes (lineas path = ZEUS_VOLUMES_ROOT + DISK_02/LINEAS per volumes.json)
# Ajustar a la ruta absoluta de VOLUMES en tu máquina (p. ej. <repo>/VOLUMES)
ZEUS_VOLUMES_ROOT=./VOLUMES

# Optional: override remote Firehose sync source
# ZEUS_FIREHOSE_REMOTE_PATH=C:/path/to/WiringEditor/data/firehose

# Optional: SSB OASIS pub export (WP-U84) — JSON log dump, files-first sync
# ZEUS_SSB_LOG_PATH=C:/path/to/oasis-pub-ssb-log.json
# ZEUS_SSB_PUB_URL=https://pub.example  # provenance only; sync does not dial the pub

# Optional: prensa API base URL for Tablero ALEPH links
# ZEUS_PRENSA_BASE_URL=http://localhost:8080/prensa/caso

# Optional: external lineas tree for re-import only
# ZEUS_LINEAS_IMPORT_SOURCE=C:/path/to/lineas-backup

# Optional: external medidor casos tree for re-import only
# ZEUS_MEDIDOR_IMPORT_SOURCE=C:/path/to/medidor-poder-politico/data/casos

# Optional: contract validation (enforce | warn | off; also 0/false and 1/true)
# ZEUS_VALIDATE=enforce
# ZEUS_HTTP_VALIDATE=enforce
# ZEUS_SOCKET_VALIDATE=enforce

# Optional: validate MCP resource payloads against Zod schemas (smoke / CI)
# ZEUS_VALIDATE_RESOURCES=1

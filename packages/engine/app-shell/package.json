{
  "name": "@zeus/app-shell",
  "version": "0.2.2",
  "description": "Shared app bootstrap factories for Zeus UI packages",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.mjs"
    },
    "./create-app-config": {
      "types": "./types/create-app-config.d.ts",
      "default": "./src/create-app-config.mjs"
    },
    "./create-theme-handler": {
      "types": "./types/create-theme-handler.d.ts",
      "default": "./src/create-theme-handler.mjs"
    },
    "./create-shell-views": {
      "types": "./types/create-shell-views.d.ts",
      "default": "./src/create-shell-views.mjs"
    },
    "./ssr-view-registry": {
      "types": "./types/ssr-view-registry.d.ts",
      "default": "./src/ssr-view-registry.mjs"
    }
  },
  "scripts": {
    "test": "node --test test/*.mjs"
  },
  "zeus": {
    "role": "lib",
    "docs": {
      "repo": [
        "packages/mesh/player-ui/spec/openapi.yaml"
      ]
    }
  },
  "dependencies": {
    "@zeus/presets-sdk": "0.1.2",
    "@zeus/rooms": "0.1.1",
    "@zeus/ui-kit": "0.1.2",
    "hyperaxe": "^3.0.2"
  },
  "license": "AIPLv1",
  "publishConfig": {
    "registry": "https://npm.scriptorium.escrivivir.co"
  },
  "files": [
    "src",
    "README.md",
    "types"
  ],
  "types": "./types/index.d.ts"
}

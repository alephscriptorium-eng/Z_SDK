{
  "name": "@zeus/game-engine",
  "version": "0.1.3",
  "description": "Pure-logic gamemap engine + scenes + Alephillo/gamething specs. Browser-safe src/, served raw via express.static + import maps. Game-agnostic (D-8): consumers supply scenes/content.",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.mjs"
    },
    "./node": {
      "types": "./types/node.d.ts",
      "default": "./src/node.mjs"
    }
  },
  "scripts": {
    "test": "node --test test/*.test.mjs"
  },
  "license": "AIPLv1",
  "zeus": {
    "role": "lib"
  },
  "dependencies": {
    "@zeus/protocol": "0.4.0"
  },
  "publishConfig": {
    "registry": "https://npm.scriptorium.escrivivir.co"
  },
  "files": [
    "src",
    "assets",
    "README.md",
    "types"
  ],
  "types": "./types/index.d.ts"
}

{
  "name": "@zeus/room-client-browser",
  "version": "0.1.4",
  "description": "Browser room-session client for scriptorium /runtime (SET_STATE + ROOM_MESSAGE)",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.mjs"
    },
    "./browser": {
      "types": "./types/browser.d.ts",
      "default": "./browser/room-client.browser.mjs"
    },
    "./dev-config": {
      "types": "./types/dev-config.d.ts",
      "default": "./browser/dev-room-config.mjs"
    }
  },
  "scripts": {
    "test": "node --experimental-test-module-mocks --test test/*.mjs"
  },
  "dependencies": {
    "@zeus/presets-sdk": "0.1.3",
    "@zeus/rooms": "0.1.2",
    "socket.io-client": "^4.8.1"
  },
  "license": "AIPLv1",
  "zeus": {
    "role": "lib"
  },
  "publishConfig": {
    "registry": "https://npm.scriptorium.escrivivir.co"
  },
  "files": [
    "src",
    "browser",
    "README.md",
    "types"
  ],
  "types": "./types/index.d.ts"
}

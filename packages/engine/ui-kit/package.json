        "packages/mesh/player-ui/spec/openapi.yaml"
      ]
    }
  },
  "devDependencies": {
    "@zeus/presets-sdk": "0.1.2"
  },
  "dependencies": {
    "@zeus/http-contract": "0.1.2",
    "express": "^5.2.1",
    "hyperaxe": "^3.0.2",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "registry": "https://npm.scriptorium.escrivivir.co"
  },
  "files": [
    "src",
    "assets",
    "README.md"

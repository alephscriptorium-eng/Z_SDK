{
  "name": "@zeus/ui-kit",
  "version": "0.1.2",
  "description": "Shared Zeus UI shell: template, navigation, themes and base assets",
  "type": "module",
  "main": "src/index.mjs",
  "scripts": {
    "build:json-path": "node scripts/generate-json-path-browser.mjs",
    "test": "node --test test/*.mjs"
  },
  "exports": {
    ".": "./src/index.mjs",
    "./theme-contract": "./src/theme-contract.mjs"
  },
  "license": "AIPLv1",
  "zeus": {

  "description": "HTTP REST contract core: RouteEntry manifests, zod envelopes, OpenAPI generation, RouteEntry→MCP projection, route coverage, express validation middleware",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./express": "./src/middleware.mjs",
    "./mcp-resources": "./src/mcp-resources/index.mjs",
    "./spec": "./spec/mcp-resources.md"
  },
  "scripts": {
    "test": "node --test test/*.mjs",
    "spec:generate": "node spec/generate.mjs"
  },
  "license": "AIPLv1",
  "zeus": {
    "role": "lib"
  },
  "dependencies": {

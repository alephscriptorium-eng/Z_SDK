{
  "name": "@zeus/http-contract",
  "version": "0.1.3",
  "description": "HTTP REST contract core: RouteEntry manifests, zod envelopes, OpenAPI generation, RouteEntry→MCP projection, route coverage, express validation middleware",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.mjs"
    },
    "./express": {
      "types": "./types/express.d.ts",
      "default": "./src/middleware.mjs"
    },
    "./mcp-resources": {
      "types": "./types/mcp-resources.d.ts",
      "default": "./src/mcp-resources/index.mjs"
    },
    "./spec": "./spec/mcp-resources.md"
  },
  "scripts": {
    "test": "node --test test/*.mjs",
    "spec:generate": "node spec/generate.mjs"
  },
  "license": "AIPLv1",
  "zeus": {
    "role": "lib"
  },
  "dependencies": {
    "@zeus/presets-sdk": "0.1.3",
    "yaml": "^2.8.0",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "registry": "https://npm.scriptorium.escrivivir.co"
  },
  "files": [
    "src",
    "spec",
    "README.md",
    "types"
  ],
  "types": "./types/index.d.ts"
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zeus.local/schemas/ssb-manifest.json",
  "title": "SsbManifest",
  "description": "DISK_04/SSB/manifest.json — export snapshot of OASIS pub typed messages (DATOS.md §3/§7)",
  "type": "object",
  "required": ["schema", "version", "volume", "disk", "path", "syncedAt", "corpora"],
  "additionalProperties": true,
  "properties": {
    "schema": { "type": "string", "const": "ssb-manifest" },
    "version": { "type": "integer", "minimum": 1 },
    "volume": { "type": "string", "const": "ssb" },
    "disk": { "type": "string", "const": "DISK_04" },
    "path": { "type": "string", "minLength": 1 },
    "syncedAt": { "type": "string", "minLength": 1 },
    "source": { "type": "object", "additionalProperties": true },
    "totals": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "input": { "type": "integer", "minimum": 0 },
        "exported": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 }
      }
    },
    "corpora": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "label": { "type": "string" },
          "files": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "typesKnown": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

{
  "name": "@zeus/story-board-schema",
  "version": "0.1.0",
  "description": "Canonical story-board JSON Schema + AJV validator (acts→widgets dialects)",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./validate": "./src/validate.mjs",
    "./schema": "./src/schema.mjs",
    "./schemas/*": "./schemas/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs"
  },
  "license": "AIPLv1",
  "zeus": {
    "role": "lib"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "publishConfig": {
    "registry": "https://npm.scriptorium.escrivivir.co"
  },
  "files": [
    "src",
    "schemas",
    "README.md"
  ]
}

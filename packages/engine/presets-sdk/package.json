{
  "name": "@zeus/presets-sdk",
  "version": "0.1.3",
  "description": "MCP catalog & presets SDK: discovery, extraction, preset persistence, volumes and HTTP routes",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": {
      "types": "./src/types.d.ts",
      "default": "./src/index.mjs"
    },
    "./env": {
      "types": "./src/env/index.d.ts",
      "default": "./src/env/index.mjs"
    },
    "./docs": {
      "types": "./src/docs/index.d.ts",
      "default": "./src/docs/index.mjs"
    },
    "./paths": {
      "types": "./src/paths/index.d.ts",
      "default": "./src/paths/index.mjs"
    },
    "./discovery": {
      "types": "./src/discovery/index.d.ts",
      "default": "./src/discovery/index.mjs"
    },
    "./mcp": {
      "types": "./src/mcp/index.d.ts",
      "default": "./src/mcp/index.mjs"
    },
    "./volumes": {
      "types": "./src/volumes/index.d.ts",
      "default": "./src/volumes/index.mjs"
    },
    "./browse-core": {
      "types": "./src/volumes/browse-core.d.ts",
      "default": "./src/volumes/browse-core.mjs"
    },
    "./anchor-grid": {
      "types": "./src/paths/anchor-grid.d.ts",
      "default": "./src/paths/anchor-grid.mjs"
    },
    "./presets/contract": "./src/presets/contract.mjs",
    "./mcp/http-contract": "./src/mcp/http-contract.mjs",
    "./horse": "./src/horse/index.mjs"
  },
  "scripts": {
    "test": "node --test test/*.mjs",
    "spec:generate": "node spec/generate.mjs"
  },
  "license": "AIPLv1",
  "zeus": {
    "role": "lib",
    "docs": {
      "package": [
        "src/env/index.mjs"
      ]
    }
  },
  "dependencies": {
    "@zeus/http-contract": "0.1.3",
    "@zeus/ui-kit": "0.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "archiver": "^7.0.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "swagger-ui-dist": "^5.29.0",
    "yaml": "^2.8.0",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "registry": "https://npm.scriptorium.escrivivir.co"
  },
  "files": [
    "src",
    "README.md"
  ]
}

{
  "name": "@zeus/protocol",
  "version": "0.2.0",
  "description": "Contrato único Zeus: envelope state|intent|track|ledger, makeIntent, roles, gates, Peer Card, AsyncAPI",
  "type": "module",
  "main": "src/index.mjs",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.mjs"
    },
    "./contract": "./src/contract.mjs",
    "./roles": "./src/roles.mjs",
    "./gates": "./src/gates.mjs",
    "./peer-card": "./src/peer-card.mjs",
    "./peer-card-seat": "./src/peer-card-seat.mjs",
    "./node-src-dir": "./src/node-src-dir.mjs",
    "./node": "./src/node.mjs",
    "./spec": "./spec/asyncapi.yaml",
    "./spec/build": "./spec/build.mjs"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "spec:generate": "node spec/generate.mjs",
    "types:generate": "node spec/generate-types.mjs"
  },
  "license": "AIPLv1",
  "zeus": {
    "role": "lib"
  },
  "dependencies": {
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@zeus/http-contract": "0.1.2"
  },
  "publishConfig": {
    "registry": "https://npm.scriptorium.escrivivir.co"
  },
  "files": [
    "src",
    "spec",
    "types",
    "README.md"
  ]
}

{
  "name": "@zeus/protocol",
  "version": "0.4.0",
  "description": "Contrato único Zeus: envelope state|intent|track|ledger, makeIntent, roles, gates, ACL, Peer Card, AsyncAPI",
  "type": "module",
  "main": "src/index.mjs",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.mjs"
    },
    "./contract": {
      "types": "./types/contract.d.ts",
      "default": "./src/contract.mjs"
    },
    "./roles": {
      "types": "./types/roles.d.ts",
      "default": "./src/roles.mjs"
    },
    "./gates": {
      "types": "./types/gates.d.ts",
      "default": "./src/gates.mjs"
    },
    "./acl": {
      "types": "./types/acl.d.ts",
      "default": "./src/acl.mjs"
    },
    "./peer-card": {
      "types": "./types/peer-card.d.ts",
      "default": "./src/peer-card.mjs"
    },
    "./peer-card-seat": {
      "types": "./types/peer-card-seat.d.ts",
      "default": "./src/peer-card-seat.mjs"
    },
    "./node-src-dir": {
      "types": "./types/node-src-dir.d.ts",
      "default": "./src/node-src-dir.mjs"
    },
    "./node": {
      "types": "./types/node.d.ts",
      "default": "./src/node.mjs"
    },
    "./spec": "./spec/asyncapi.yaml",
    "./spec/build": "./spec/build.mjs"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "spec:generate": "node spec/generate.mjs",
    "types:generate": "node spec/generate-types.mjs"
  },
  "license": "AIPLv1",
  "zeus": {
    "role": "lib"
  },
  "dependencies": {
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@zeus/http-contract": "0.1.2"
  },
  "publishConfig": {
    "registry": "https://npm.scriptorium.escrivivir.co"
  },
  "files": [
    "src",
    "spec",
    "types",
    "README.md"
  ]
}

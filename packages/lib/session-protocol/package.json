{
  "name": "@zeus/session-protocol",
  "version": "0.1.0",
  "description": "Socket.IO session protocol for Zeus player-ui: schemas, server attach, clients, AsyncAPI spec",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./client": "./src/client.mjs",
    "./schemas": "./src/schemas/index.mjs",
